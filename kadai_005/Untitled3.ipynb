      "source": [
        "# 上辺・下辺・高さを変数に代入\n",
        "upper = 10\n",
        "lower = 20\n",
        "height = 5\n",
        "\n",
        "# 台形の面積を計算して変数に代入\n",
        "area = (upper + lower) * height / 2\n",
        "\n",
        "# 結果を単位付きで出力\n",
        "print(str(area) + \"cm²\")"
      ]
